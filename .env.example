# App
APP_NAME=BirgeFund API
APP_ENV=local
DEBUG=true
TEST_MODE=true
API_PREFIX=/api

# Security
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# Database
POSTGRES_DB=birgefund
POSTGRES_USER=birgefund
POSTGRES_PASSWORD=birgefund
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://birgefund:birgefund@postgres:5432/birgefund

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Files
UPLOAD_DIR=/storage/uploads
MAX_IMAGE_SIZE_MB=5
MAX_PDF_SIZE_MB=10

# Frontend
FRONTEND_URL=http://localhost:5173
