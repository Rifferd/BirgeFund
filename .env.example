APP_NAME=BirgeFund
APP_ENV=local
APP_DEBUG=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

FRONTEND_PORT=5173

POSTGRES_DB=birgefund
POSTGRES_USER=birgefund
POSTGRES_PASSWORD=birgefund_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://birgefund:birgefund_password@postgres:5432/birgefund

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change_me_in_local_env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

TEST_MODE=true
DEFAULT_LANGUAGE=ru
AVAILABLE_LANGUAGES=ru,kg,en

UPLOAD_DIR=storage/uploads
MAX_IMAGE_SIZE_MB=5
MAX_PDF_SIZE_MB=10
