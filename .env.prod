ENVIRONMENT=production

POSTGRES_DB=birgefund
POSTGRES_USER=birgefund
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql+asyncpg://birgefund:CHANGE_ME_STRONG_PASSWORD@db:5432/birgefund

REDIS_URL=redis://redis:6379/0

SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY
JWT_SECRET_KEY=CHANGE_ME_SUPER_JWT_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

BACKEND_CORS_ORIGINS=https://birgefund.kg,https://www.birgefund.kg

UPLOAD_DIR=/app/storage/uploads
